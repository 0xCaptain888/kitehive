# KiteHive Environment Configuration
# Copy this file to .env and fill in your values.
# All required variables are marked [Required].

# ═══════════════════════════════════════════════════════════════
# LLM
# ═══════════════════════════════════════════════════════════════

# DeepSeek API — primary LLM (OpenAI-compatible)
# Get at: https://platform.deepseek.com → API Keys
# Why DeepSeek: ~15x cheaper than GPT-4o, same capability for agent tasks.
DEEPSEEK_API_KEY=your-deepseek-api-key                        # [Required]
DEEPSEEK_MODEL=deepseek-chat                                   # or deepseek-reasoner for CoT

# OpenAI API key — fallback if DEEPSEEK_API_KEY is not set
# Get at: https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-api-key                         # [Optional fallback]

# ═══════════════════════════════════════════════════════════════
# BLOCKCHAIN — WALLETS
# ═══════════════════════════════════════════════════════════════

# Main deployer wallet (for contract deployment)
# Must have testnet KITE for gas: https://faucet.gokite.ai
DEPLOYER_PRIVATE_KEY=0x-your-deployer-private-key             # [Required for deploy]

# Coordinator A wallet (balanced — explorationRate=0.18)
COORDINATOR_WALLET_KEY=0x-coordinator-a-private-key           # [Required]
COORDINATOR_A_EXPLORATION=0.18

# Coordinator B wallet (aggressive — explorationRate=0.40) [Upgrade #05]
# Use a separate private key for Coordinator B
COORDINATOR_B_WALLET_KEY=0x-coordinator-b-private-key         # [Required for upgrade #05]
COORDINATOR_B_WALLET=0x-coordinator-b-address                 # (derived from key above)
COORDINATOR_B_EXPLORATION=0.40

# Agent wallets (fund each with small testnet USDC for staking)
RESEARCH_AGENT_WALLET=0x-research-agent-address               # [Required]
WRITER_AGENT_WALLET=0x-writer-agent-a-address                 # [Required]
WRITER_AGENT_B_WALLET=0x-writer-agent-b-address               # [Required]
EXTERNAL_API_AGENT_WALLET=0x-external-api-address             # [Required]
EXTERNAL_API_AGENT_KEY=0x-external-api-private-key            # [Required for agent server]

# ═══════════════════════════════════════════════════════════════
# BLOCKCHAIN — NETWORKS
# ═══════════════════════════════════════════════════════════════

# Kite Testnet (Chain ID: 2368)
KITE_TESTNET_RPC=https://rpc-testnet.gokite.ai
KITE_RPC_URL=https://rpc-testnet.gokite.ai                    # override for dashboard

# Kite Mainnet (Chain ID: 2366) [Upgrade #03]
KITE_MAINNET_RPC=https://rpc.gokite.ai

# ═══════════════════════════════════════════════════════════════
# CONTRACT ADDRESSES (fill after deployment)
# ═══════════════════════════════════════════════════════════════

# Run: npm run deploy:testnet  → copies address here
ATTESTATION_CONTRACT_TESTNET=0x7a0b21045Ff37f79095Ee338f9d6F2f303700046
ATTESTATION_CONTRACT_ADDRESS=0x7a0b21045Ff37f79095Ee338f9d6F2f303700046 # alias for dashboard

# Run: npm run deploy:mainnet  → copies address here [Upgrade #03]
ATTESTATION_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000

# ═══════════════════════════════════════════════════════════════
# TOKENS [Upgrade #08 — PYUSD added]
# ═══════════════════════════════════════════════════════════════

# USDC on Kite Testnet (verified from on-chain history)
USDC_TOKEN_ADDR=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63

# PYUSD on Kite Testnet (update when Kite publishes address)
# PayPal USD — adds dual-currency settlement capability
PYUSD_TOKEN_ADDR=0x0000000000000000000000000000000000000000

# ═══════════════════════════════════════════════════════════════
# KITE PROTOCOLS
# ═══════════════════════════════════════════════════════════════

# Agent Passport — human-to-agent authorization
# Get at: https://developer.gokite.ai → Passport Apps
KITE_PASSPORT_CLIENT_ID=your-passport-client-id               # [Required]
KITE_PASSPORT_SECRET=your-passport-secret                     # [Required]

# x402 Facilitator
X402_FACILITATOR_URL=https://facilitator.gokite.ai

# ═══════════════════════════════════════════════════════════════
# DASHBOARD (Next.js public env vars)
# ═══════════════════════════════════════════════════════════════

# Testnet (default)
NEXT_PUBLIC_ATTESTATION_CONTRACT=0x7a0b21045Ff37f79095Ee338f9d6F2f303700046
NEXT_PUBLIC_KITE_EXPLORER=https://testnet.kitescan.ai
NEXT_PUBLIC_CHAIN_ID=2368

# Switch to mainnet [Upgrade #03]:
# NEXT_PUBLIC_ATTESTATION_CONTRACT=<mainnet contract address>
# NEXT_PUBLIC_KITE_EXPLORER=https://kitescan.ai
# NEXT_PUBLIC_CHAIN_ID=2366

# ═══════════════════════════════════════════════════════════════
# BUDGET CONFIG [Fix #01 — session budget vs economy total]
# ═══════════════════════════════════════════════════════════════

# Per-session safety cap in USD (guards against runaway LLM costs)
# This is NOT the economy total — the economy has no upper cap.
SESSION_BUDGET_CAP=10.00
