{
  "framework": "nextjs",
  "buildCommand": "cd dashboard && npm install && npm run build",
  "outputDirectory": "dashboard/.next",
  "installCommand": "cd dashboard && npm install",
  "devCommand": "cd dashboard && npm run dev",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}
