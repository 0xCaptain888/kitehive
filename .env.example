# KiteHive Environment Configuration
# Copy this file to .env and fill in your values

# === LLM ===
OPENAI_API_KEY=sk-your-openai-api-key

# === Blockchain ===
DEPLOYER_PRIVATE_KEY=0x-your-deployer-private-key

# Kite Testnet (Chain ID: 2368)
KITE_TESTNET_RPC=https://rpc-testnet.gokite.ai
# Kite Mainnet (Chain ID: 2366)
KITE_MAINNET_RPC=https://rpc.gokite.ai

# === Contract Addresses (update after deployment) ===
ATTESTATION_CONTRACT_TESTNET=0x0000000000000000000000000000000000000000
ATTESTATION_CONTRACT_MAINNET=0x0000000000000000000000000000000000000000

# === Agent Wallets ===
COORDINATOR_WALLET_KEY=0x-coordinator-private-key
RESEARCH_AGENT_WALLET=0x-research-agent-address
WRITER_AGENT_WALLET=0x-writer-agent-a-address
WRITER_AGENT_B_WALLET=0x-writer-agent-b-address

# === Agent Passport ===
KITE_PASSPORT_CLIENT_ID=your-passport-client-id
KITE_PASSPORT_SECRET=your-passport-secret

# === x402 ===
X402_FACILITATOR_URL=https://facilitator.gokite.ai

# === Dashboard ===
NEXT_PUBLIC_ATTESTATION_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_KITE_EXPLORER=https://testnet.kitescan.ai
NEXT_PUBLIC_CHAIN_ID=2368
